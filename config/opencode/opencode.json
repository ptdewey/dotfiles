{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "cd": "ask",
      "rm*": "ask",
      "cd*": "allow",
      "diff*": "allow",
      "git*": "ask",
      "git add*": "deny",
      "git pull*": "deny",
      "git rm*": "deny",
      "git commit*": "deny",
      "git stash*": "deny",
      "git checkout*": "ask",
      "git diff*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "grep*": "allow",
      "rg *": "allow",
      "go list*": "allow",
      "find*": "allow",
      "xargs*": "allow",
      "fd*": "allow",
      "jq*": "allow",
      "cat*": "allow",
      "sort": "allow",
      "head*": "allow",
      "tail*": "allow",
      "go test**": "allow",
      "go doc*": "allow",
      "go build*": "allow",
      "go run*": "allow",
      "echo*": "ask",
      "go get*": "allow",
      "go mod*": "allow",
      "go version*": "allow",
      "go tool*": "allow",
      "curl*": "ask",
      "wget*": "deny",
      "ping*": "deny",
      "jj *": "deny",
      "jj log*": "allow",
      "jj st*": "allow",
      "wc*": "allow",
      "tree*": "allow",
      "gofmt*": "allow",
      "helm*": "deny",
      "kubectl": "deny",
      "docker*": "deny",
      "docker logs*": "allow",
      "mkdir*": "allow",
      "npm run*": "allow"
    }
  },
  "plugin": ["opencode-anthropic-auth@latest"]
}
